{
  "root": true,
  "env": { "browser": true, "es2020": true },
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended",
    "plugin:react-hooks/recommended"
  ],
  "ignorePatterns": [
    "dist",
    ".eslintrc.json",
    "public/wasm/*.d.ts",
    "**/*.d.ts",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.worker.ts"
  ],
  "parser": "@typescript-eslint/parser",
  "plugins": ["react-refresh"],
  "rules": {
    "react-refresh/only-export-components": ["warn", { "allowConstantExport": true }],
    "@typescript-eslint/no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
    "@typescript-eslint/no-explicit-any": "warn",
    "@typescript-eslint/ban-ts-comment": "off",
    "no-restricted-imports": [
      "error",
      {
        "paths": [
          {
            "name": "@ui",
            "message": "Use @browser-fs-analyzer/ui"
          },
          {
            "name": "@i18n",
            "message": "Use @browser-fs-analyzer/i18n"
          },
          {
            "name": "@encryption",
            "message": "Use @browser-fs-analyzer/encryption"
          },
          {
            "name": "@conversation",
            "message": "Use @browser-fs-analyzer/conversation"
          }
        ],
        "patterns": ["@ui/*", "@i18n/*", "@encryption/*", "@conversation/*"]
      }
    ],
    "prefer-const": "error",
    "require-yield": "off"
  }
}
