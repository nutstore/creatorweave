{
  "name": "creatorweave-web",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "pnpm run build:wasm && vite build && pnpm run copy:eo-runtime && pnpm run copy:pyodide",
    "build:wasm": "cd ../wasm && bash scripts/build-wasm.sh",
    "build:vercel": "pnpm run build:wasm && vite build && pnpm run copy:eo-runtime && pnpm run copy:pyodide",
    "copy:eo-runtime": "rm -f dist/middleware.js dist/package.json && rm -rf dist/cloud-functions && cp ../edgeone.json dist/edgeone.json",
    "copy:pyodide": "mkdir -p dist/assets/pyodide && cp -r node_modules/pyodide/* dist/assets/pyodide/",
    "preview": "vite preview",
    "preview:prod": "pnpm build && vite preview --port 3000",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@creatorweave/config": "workspace:*",
    "@creatorweave/encryption": "workspace:*",
    "@creatorweave/i18n": "workspace:*",
    "@creatorweave/ui": "workspace:*",
    "@iconify/react": "^6.0.2",
    "@mariozechner/pi-agent-core": "^0.73.0",
    "@mariozechner/pi-ai": "^0.73.0",
    "@monaco-editor/react": "^4.7.0",
    "@mozilla/readability": "^0.6.0",
    "@sqlite.org/sqlite-wasm": "3.51.2-build6",
    "@tiptap/core": "^3.20.5",
    "@tiptap/extension-code": "^3.20.5",
    "@tiptap/extension-document": "^3.20.5",
    "@tiptap/extension-hard-break": "^3.20.5",
    "@tiptap/extension-history": "^3.20.5",
    "@tiptap/extension-mention": "^3.20.5",
    "@tiptap/extension-paragraph": "^3.20.5",
    "@tiptap/extension-text": "^3.20.5",
    "@tiptap/pm": "^3.20.5",
    "@tiptap/react": "^3.20.5",
    "@tiptap/suggestion": "^3.20.5",
    "@types/qrcode.react": "^1.0.5",
    "@webcontainer/api": "^1.5.1",
    "@xyflow/react": "^12.10.2",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "diff": "^8.0.3",
    "docx-preview": "^0.3.6",
    "file-saver": "^2.0.5",
    "html2canvas": "^1.4.1",
    "idb": "^8.0.0",
    "immer": "^11.1.3",
    "js-yaml": "^4.1.1",
    "jspdf": "^2.5.2",
    "lucide-react": "^0.460.0",
    "micromatch": "^4.0.8",
    "monaco-editor": "^0.55.1",
    "pyodide": "^0.29.3",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-split-pane": "^3.2.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "shiki": "^3.21.0",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.5",
    "turndown": "^7.2.2",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@eslint/js": "8",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chart.js": "^4.0.1",
    "@types/diff": "^8.0.0",
    "@types/file-saver": "^2.0.7",
    "@types/js-yaml": "^4.0.9",
    "@types/micromatch": "^4.0.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "happy-dom": "^20.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.10",
    "react-scan": "^0.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss}": [
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
