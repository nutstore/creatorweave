{
  "name": "browser-extension",
  "version": "1.0.5",
  "description": "A browser extension that provides web_search and web_fetch capabilities for in-browser Agents",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "watch": "wxt build --watch",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@types/turndown": "^5.0.5",
    "wxt": "^0.19.0"
  },
  "keywords": [
    "chrome-extension",
    "agent",
    "web-search",
    "web-fetch"
  ],
  "license": "MIT"
}
